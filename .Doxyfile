PROJECT_NAME           = "nuklear_console"
PROJECT_BRIEF          = "Console-style widget system for Nuklear"
OUTPUT_DIRECTORY       = build/doxygen
FILE_PATTERNS          = *.h
RECURSIVE              = NO
GENERATE_HTML          = NO
